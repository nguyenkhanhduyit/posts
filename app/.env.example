# Optional: default Facebook credentials (used when UI leaves fields empty)
FB_EMAIL=
FB_PASSWORD=

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8080

# Storage
SQLITE_PATH=app/storage/app.db
CHROME_PROFILE_DIR=app/chrome-profile

# Worker defaults
DEFAULT_MAX_POSTS=30
DEFAULT_DELAY_MIN_SEC=1
DEFAULT_DELAY_MAX_SEC=3

# Switching keywords faster (set 0 to disable cooldown)
DEFAULT_BETWEEN_KEYWORDS_DELAY_MIN_SEC=1
DEFAULT_BETWEEN_KEYWORDS_DELAY_MAX_SEC=2

# UI / workers (supervisor reads worker_count from DB; this is only a default before first UI save)
DEFAULT_MAX_KEYWORDS=500
DEFAULT_WORKER_COUNT=1

# Post screenshot classifier (negative-only). If POST_CLASSIFIER_ENABLED is unset/empty, worker auto-enables
# only when app/worker/post_classifier/model.json exists and kind is deep/hybrid/rejector (NOT legacy linear_v1).
# POST_CLASSIFIER_ENABLED=0 disables even if a trained model exists.
# POST_CLASSIFIER_ENABLED=1 forces ON (even if model is missing / legacy).
POST_CLASSIFIER_ENABLED=
POST_CLASSIFIER_BUDGET_SEC=3.5
POST_CLASSIFIER_REJECT_THRESHOLD=0.85
POST_CLASSIFIER_POS_THRESHOLD=0.60
POST_CLASSIFIER_ENGINE=deep
POST_CLASSIFIER_ONNX_VARIANT=fp32
POST_CLASSIFIER_DEEP_RECHECK_MARGIN=0.03
POST_CLASSIFIER_DEEP_EMB_CACHE=256
POST_CLASSIFIER_ORT_INTER_THREADS=0
POST_CLASSIFIER_DEEP_RP_DIM=128
POST_CLASSIFIER_DEEP_SAMPLE_M=256
POST_CLASSIFIER_DEEP_POS_VETO=1
POST_CLASSIFIER_DEEP_VETO_POS_THRESHOLD=0.80
POST_CLASSIFIER_OPENSET_GATING=1
POST_CLASSIFIER_GATING_MARGIN=0.06
POST_CLASSIFIER_GATING_MAX_BOOST=0.10
POST_CLASSIFIER_BACKBONE=mobilenetv3
POST_CLASSIFIER_FOUNDATION_ENABLED=0
POST_CLASSIFIER_FOUNDATION_ONNX_URL=
POST_CLASSIFIER_FOUNDATION_MARGIN=0.04
POST_CLASSIFIER_FOUNDATION_MIN_BUDGET_LEFT=1.2
POST_CLASSIFIER_FOUNDATION_MAX_SAMPLES=300
POST_CLASSIFIER_FOUNDATION_RP_DIM=128
POST_CLASSIFIER_FOUNDATION_REJECT_THRESHOLD=
POST_CLASSIFIER_FOUNDATION_EMB_CACHE=64
POST_CLASSIFIER_FOUNDATION_HARD_MIN=0.35
POST_CLASSIFIER_FOUNDATION_POS_THRESHOLD=
POST_CLASSIFIER_FOUNDATION_BINARY_MARGIN=0.06
POST_CLASSIFIER_FOUNDATION_BINARY_SUGGESTED_THRESHOLD=0.60
POST_CLASSIFIER_TRAIN_MODE=auto
POST_CLASSIFIER_POS_DIR=
POST_CLASSIFIER_NEG_DIR=
POST_CLASSIFIER_AUTO_COLLECT=0
POST_CLASSIFIER_AUTO_COLLECT_MARGIN=0.06

# When using 2+ Playwright workers, auto-opening the web UI in your default browser often launches ANOTHER Chrome window.
# Supervisor skips auto-open when worker_count>=2. You can still force behavior:
# OPEN_UI_BROWSER=1  -> try to open UI in browser (only if worker_count<2)
# OPEN_UI_BROWSER=0  -> never auto-open
OPEN_UI_BROWSER=1

# If FB scroll/capture feels "stuck" when the automation window is in background, set 1 to reduce background throttling flags.
FB_KEEP_SCROLL_ACTIVE=0

